<div class="portada">
    <div class="contenedor" style="display: flex; height: 100%">
        <div class="loginLeft" style="">
            <img alt="Escapp" id="coverImage" src="/images/puzzle.png" width="80%"/>
        </div>
        <div class="loginRight">
           <% if(locals.register) { %>
                <%- include("users/_form.ejs") %>
           <%  } else if (locals.resetPassword) { %>
                <%- include("users/_resetPassword.ejs") %>   
           <%  } else if (locals.resetPasswordHash) { %>
                <%- include("users/_resetPasswordHash.ejs") %>
           <%  } else { %>
                <%- include("users/_login.ejs") %>
           <% } %>
          <ul class="langs">
               <% var langs = locals.globalConfig.availableLanguages || ["en", "es"]; %>
               <% for (var l in langs) {
                    var ll = langs[l];
                    %>
               <% if (l != 0) { %> / <%}%>
                    <li><a class="<%=(i18n.lang==ll?"active":"")%>" href="/?clang=<%=ll%>"><%=ll%></a></li>
               <%}%>
          </ul>
        </div>
        <div class="loginLeftHeader">
          <a title="<%=i18n.common.guide%>" href="/manual"><span class="navBarIcon material-icons">help_outline</span></a>
          <span style="display:inline-block;width:10px;"></span>
          <a title="<%=i18n.network.title%>" href="/network/search?query="><span class="navBarIcon material-icons">language</span></a>
          <span style="display:inline-block;width:10px;"></span>
        </div>
    </div>
</div>
<%- include ("partials/_footer.ejs") %>