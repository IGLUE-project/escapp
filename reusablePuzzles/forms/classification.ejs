<br>
<%- include ("./_validator.ejs", {allowedValidators: ["exact"], allowedNullPuzzle: false}, ) %>
<br>
<h4 class="titleLabelEdit"> <%=i18n.escapeRoom.steps.indications.front.catalog.config.customization%> </h4>

<div>
    <label for="skinSelect"><%=i18n.reusablePuzzleApps.Common.skin%>:</label>
    <select id="skinSelect" name="skin">
        <option value="STANDARD"><%=i18n.reusablePuzzleApps.Common.skins.Standard%></option>
        <option value="RETRO"><%=i18n.reusablePuzzleApps.Common.skins.Retro%></option>
        <option value="FUTURISTIC"><%=i18n.reusablePuzzleApps.Common.skins.Futuristic%></option>
    </select>
</div>

<div>
    <label for="actionValue"><%=i18n.reusablePuzzleApps.Common.actionAfterSolve%>:</label>
    <select id="actionValue" name="actionAfterSolve">
        <option value="NONE"><%=i18n.reusablePuzzleApps.Common.NoneF%></option>
        <option value="SHOW_MESSAGE"><%=i18n.reusablePuzzleApps.Common.showMessage%></option>
    </select>
</div>

<div id="actionDiv">
    <label for="messageInput"><%=i18n.reusablePuzzleApps.Common.Message%>:</label>
    <input id="messageInput" type="text" name="message" placeholder="<%=i18n.reusablePuzzleApps.Common.MessagePlaceholder%>"  style="flex:1;"  />
</div>

<div>
     <%- include ("./_asset.ejs", {
        assetId: "backgroundImgInput", 
        assetName: "backgroundImg", 
        assetLabel: i18n.reusablePuzzleApps.Common.BackgroundURL,
        assetPlaceholder: i18n.reusablePuzzleApps.Common.BackgroundURLPlaceholder,
        assetFilter: "image",
        assetRequired: false,
        allowEmpty: true
    } ) %>
   </div>

<div>
    <label for="leftTitleInput"><%=i18n.reusablePuzzleApps.Classification.leftTitle%>:</label>
    <input type="text" id="leftTitleInput" name="leftTitle" placeholder="<%=i18n.reusablePuzzleApps.Classification.leftTitlePlaceholder%>" style="flex:1;" />
</div>

<div>
    <label for="rightTitleInput"><%=i18n.reusablePuzzleApps.Classification.rightTitle%>:</label>
    <input type="text" id="rightTitleInput" name="rightTitle" placeholder="<%=i18n.reusablePuzzleApps.Classification.rightTitlePlaceholder%>" style="flex:1;" />
</div>

<div>
    <label for="confirmationTextInput"><%=i18n.reusablePuzzleApps.Classification.confirmationText%>:</label>
    <input type="text" id="confirmationTextInput" name="confirmationText" placeholder="<%=i18n.reusablePuzzleApps.Classification.confirmationTextPlaceholder%>" style="flex:1;" />
</div>

<div style="margin: 15px 0px;">
    <label><%=i18n.reusablePuzzleApps.Classification.images%>:</label>
    <input type="hidden" id="classificationImagesInput" name="initialImages" />

    <!-- Shared datalist for image assets -->
    <datalist id="classificationImageAssetsList"></datalist>

    <div id="classificationImagesWrapper" style="flex-direction: column;">
        <% const defaultTitles = [i18n.reusablePuzzleApps.Classification.defaultTitle1, i18n.reusablePuzzleApps.Classification.defaultTitle2]; %>
        <% for (let i = 1; i <= 2; i++) { %>
            <div class="classificationImageWrapper" imageNumber="<%=i%>" style="flex-direction: column; border: 1px solid white; padding: 0px 10px 5px 10px; border-radius: 20px; margin: 10px 0px;">
                <div style="position: relative;">
                    <p style="margin: 7px 0px 5px 0px;"><%=i18n.reusablePuzzleApps.Classification.image + " " + i%></p>
                    <button class="deleteClassificationImage" type="button" style="display:none; border: none; background: none; position: absolute; right: 0; top: 0; align-self: center; font-size: 22px;" onclick="deleteClassificationImage(event)">
                        <span style="color: rgb(185, 62, 68);" class="material-icons">delete_outline</span>
                    </button>
                </div>
                <div>
                    <label><%=i18n.reusablePuzzleApps.Classification.imageTitle%>:</label>
                    <input class="inputImageTitle" type="text" value="<%=defaultTitles[i-1]%>" placeholder="<%=i18n.reusablePuzzleApps.Classification.imageTitlePlaceholder%>" style="flex:1;" />
                </div>
                <div style="margin: 10px 0px 10px 0px;">
                    <label><%=i18n.reusablePuzzleApps.Classification.imageSrc%>:</label>
                    <div style="display: flex; align-items: center; flex: 1;">
                        <input class="inputImageSrc" type="text" list="classificationImageAssetsList" placeholder="<%=i18n.reusablePuzzleApps.Classification.imageSrcPlaceholder%>" style="flex:1;" />
                        <button type="button" class="clearImageSrc" style="display: none; border: none; background: none; cursor: pointer; padding: 0 5px; font-size: 18px; color: rgb(185, 62, 68);">
                            <span class="material-icons">close</span>
                        </button>
                    </div>
                </div>
            </div>
        <% } %>

        <button class="rounded small addClassificationImage" type="button" onclick="addClassificationImage(event);" style="background-color: white;">
            <span class="material-icons" style="color: #161938">add</span> <%=i18n.reusablePuzzleApps.Classification.addImage%>
        </button>
    </div>
</div>
<br>

<script>
    // Action after solve toggle
    document.getElementById('actionValue').addEventListener('change', function() {
        if (this.value === 'SHOW_MESSAGE') {
            document.getElementById("actionDiv").style.display = 'flex';
        } else {
            document.getElementById("actionDiv").style.display = 'none';
        }
    });

    // Populate shared datalist with image assets
    const classificationAssetMap = {};
    const classificationOrigin = window.location.origin;
    const classificationDatalist = document.getElementById('classificationImageAssetsList');

    (window.assets || []).filter(asset => asset.assetType && asset.assetType.toLowerCase().includes('image')).forEach(asset => {
        let url = asset.url || `/assets/${asset.id}`;
        if (url.startsWith('/')) {
            url = classificationOrigin + url;
        } else if (!url.startsWith('http')) {
            url = classificationOrigin + '/assets/' + url;
        }
        classificationAssetMap[asset.filename] = url;

        const option = document.createElement('option');
        option.value = asset.filename;
        option.setAttribute('data-url', url);
        classificationDatalist.appendChild(option);
    });

    // Handle clear button visibility
    function updateClearButtonVisibility(input) {
        const clearBtn = input.closest('div').querySelector('.clearImageSrc');
        if (clearBtn) {
            clearBtn.style.display = input.value ? 'block' : 'none';
        }
    }

    // Initialize clear buttons for existing inputs
    document.querySelectorAll('.inputImageSrc').forEach(function(input) {
        updateClearButtonVisibility(input);
    });

    // Update images JSON
    function updateClassificationImages() {
        var images = [];
        document.querySelectorAll('#classificationImagesWrapper .classificationImageWrapper').forEach(function(wrapper, index) {
            var image = {};
            image.id = index + 1;
            image.title = wrapper.querySelector('input.inputImageTitle').value;
            image.src = wrapper.querySelector('input.inputImageSrc').value;
            images.push(image);
        });
        document.getElementById('classificationImagesInput').value = JSON.stringify(images);
    }

    // Add new image
    function addClassificationImageToWrapper(wrapper) {
        var $wrapper = $(wrapper);
        var $allImages = $wrapper.find('.classificationImageWrapper');
        var $firstImage = $allImages.first();
        if ($firstImage.length === 0) return;
        var imageNumber = $allImages.length + 1;
        if (imageNumber > 24) return;
        var $newImage = $firstImage.clone();
        $newImage.attr('imageNumber', imageNumber);
        $newImage.find('p').first().html('<%=i18n.reusablePuzzleApps.Classification.image%> ' + imageNumber);
        $newImage.find('button.deleteClassificationImage').first().show();
        $newImage.find('input.inputImageTitle').val('');
        $newImage.find('input.inputImageSrc').val('');
        $newImage.find('.clearImageSrc').hide();
        $wrapper.find('button.addClassificationImage').before($newImage);
        if (imageNumber === 24) {
            var $addButton = $wrapper.find('button.addClassificationImage');
            $addButton.attr('disabled', 'disabled');
            $addButton.css('background-color', '#999');
        }
        updateClassificationImages();
    }

    function addClassificationImage(e) {
        e.stopPropagation();
        e.preventDefault();
        var wrapper = document.getElementById('classificationImagesWrapper');
        addClassificationImageToWrapper(wrapper);
    }

    // Delete image
    function deleteClassificationImage(e) {
        e.stopPropagation();
        e.preventDefault();
        var $imageWrapper = $(e.target).closest('.classificationImageWrapper');
        if ($imageWrapper.length !== 1) return;
        var $imagesWrapper = $imageWrapper.parent('#classificationImagesWrapper');
        if ($imagesWrapper.length !== 1) return;
        $imageWrapper.remove();
        $imagesWrapper.find('.classificationImageWrapper').each(function(index) {
            $(this).attr('imageNumber', index + 1);
            $(this).find('p').first().text('<%=i18n.reusablePuzzleApps.Classification.image%> ' + (index + 1));
        });
        var $addButton = $imagesWrapper.find('button.addClassificationImage');
        $addButton.removeAttr('disabled');
        $addButton.css('background-color', 'white');
        updateClassificationImages();
    }

    // Clear image src button click handler (delegated)
    $('#classificationImagesWrapper').on('click', '.clearImageSrc', function(e) {
        e.preventDefault();
        var input = $(this).closest('div').find('.inputImageSrc');
        input.val('');
        $(this).hide();
        updateClassificationImages();
    });

    // Convert filename to URL when selecting from datalist, and update clear button
    $('#classificationImagesWrapper').on('change', 'input.inputImageSrc', function() {
        var selectedName = this.value;
        if (classificationAssetMap[selectedName]) {
            this.value = classificationAssetMap[selectedName];
        }
        updateClearButtonVisibility(this);
        updateClassificationImages();
    });

    // Update clear button on input
    $('#classificationImagesWrapper').on('input', 'input.inputImageSrc', function() {
        updateClearButtonVisibility(this);
    });

    // Load config values
    document.getElementById("backgroundImgInput").value = window.currentOpenPuzzleConfig?.backgroundImg || '';
    document.getElementById("messageInput").value = window.currentOpenPuzzleConfig?.message || '';
    document.getElementById("skinSelect").value = window.currentOpenPuzzleConfig?.skin || 'STANDARD';
    document.getElementById("actionValue").value = window.currentOpenPuzzleConfig?.actionAfterSolve || 'NONE';
    document.getElementById("leftTitleInput").value = window.currentOpenPuzzleConfig?.leftTitle || '';
    document.getElementById("rightTitleInput").value = window.currentOpenPuzzleConfig?.rightTitle || '';
    document.getElementById("confirmationTextInput").value = window.currentOpenPuzzleConfig?.confirmationText || '';

    // Load existing images or initialize with defaults
    if (window.currentOpenPuzzleConfig?.initialImages) {
        var images = window.currentOpenPuzzleConfig.initialImages;
        if (typeof images === 'string') {
            try { images = JSON.parse(images); } catch(e) { images = []; }
        }
        if (Array.isArray(images)) {
            var $imagesWrapper = $('#classificationImagesWrapper');
            for (var i = 0; i < images.length; i++) {
                var imageNumber = i + 1;
                if (imageNumber > 2) {
                    addClassificationImageToWrapper($imagesWrapper[0]);
                }
                var $imageDiv = $imagesWrapper.find(".classificationImageWrapper[imageNumber='" + imageNumber + "']");
                $imageDiv.find('input.inputImageTitle').val(images[i].title || '');
                var srcInput = $imageDiv.find('input.inputImageSrc');
                srcInput.val(images[i].src || '');
                updateClearButtonVisibility(srcInput[0]);
            }
        }
    }
    // Always update to save current state (defaults or loaded values)
    updateClassificationImages();

    // Toggle action div visibility
    if (window.currentOpenPuzzleConfig?.actionAfterSolve === 'SHOW_MESSAGE') {
        document.getElementById("actionDiv").style.display = 'block';
    } else {
        document.getElementById("actionDiv").style.display = 'none';
    }

    // Event listeners for title inputs
    $('#classificationImagesWrapper').on('change', 'input.inputImageTitle', updateClassificationImages);
</script>