<br>
<%- include ("./_validator.ejs", {allowedValidators: ["exact"], allowedNullPuzzle: true}, ) %>
<br>
<h4 class="titleLabelEdit"> <%=i18n.escapeRoom.steps.indications.front.catalog.config.customization%> </h4>

<div>
    <label for="skinSelect"><%=i18n.reusablePuzzleApps.Common.skin%>:</label>
    <select id="skinSelect" name="skin">
        <option value="STANDARD"><%=i18n.reusablePuzzleApps.Common.skins.Smartphone%></option>
        <option value="RETRO"><%=i18n.reusablePuzzleApps.Telephone.rotaryPhone%></option>
    </select>
</div>

<div id="showLightFeedbackDiv">
    <label for="showLightFeedback"><%=i18n.reusablePuzzleApps.Telephone.showFeedbackLight%>:</label>
    <select name="showLightFeedback" id="showLightFeedback">
        <option value="TRUE"><%=i18n.reusablePuzzleApps.Common.Yes%></option>
        <option value="FALSE"><%=i18n.reusablePuzzleApps.Common.No%></option>
    </select>
</div>

<div>
    <label for=""><%=i18n.reusablePuzzleApps.Telephone.elementType%>:</label>
    <select name="keysType" id="keysType">
        <option value="NUMBERS"><%=i18n.reusablePuzzleApps.Common.Numbers%></option>
        <option value="LETTERS"><%=i18n.reusablePuzzleApps.Common.Letters%></option>
        <option value="COLORS"><%=i18n.reusablePuzzleApps.Common.Colors%></option>
        <option value="SYMBOLS"><%=i18n.reusablePuzzleApps.Common.Symbols%></option>
    </select>
</div>

<div>
    <label for="actionValue"><%=i18n.reusablePuzzleApps.Common.actionAfterSolve%>:</label>
    <select id="actionValue" name="actionAfterSolve">
        <option value="NONE"><%=i18n.reusablePuzzleApps.Common.NoneF%></option>
        <option value="SHOW_MESSAGE"><%=i18n.reusablePuzzleApps.Common.showMessage%></option>
        <option value="PLAY_SOUND"><%=i18n.reusablePuzzleApps.Common.playSound%></option>
    </select>
</div>

<div id="messageDiv">
    <label for="messageInput"><%=i18n.reusablePuzzleApps.Common.Message%>:</label>
    <input id="messageInput" type="text" name="message" placeholder="<%=i18n.reusablePuzzleApps.Common.MessagePlaceholder%>" style="flex:1;"  />
</div>

<div id="soundDiv">
    <label for="soundInput"><%=i18n.reusablePuzzleApps.Common.soundURL%>:</label>
    <input type="text" id="soundInput" name="soundAfterSolve" placeholder="<%=i18n.reusablePuzzleApps.Common.soundURLPlaceholder%>" style="flex:1;" />
</div>

<div>
    <label for="disablePhoneAfterSolve"><%=i18n.reusablePuzzleApps.Common.disableAfterSolve%>:</label>
    <select name="disablePhoneAfterSolve" id="disablePhoneAfterSolve">
        <option value="TRUE"><%=i18n.reusablePuzzleApps.Common.Yes%></option>
        <option value="FALSE"><%=i18n.reusablePuzzleApps.Common.No%></option>
    </select>
</div>

<div>
    <%- include ("./_asset.ejs", {
        assetId: "backgroundInput",
        assetName: "background",
        assetLabel: i18n.reusablePuzzleApps.Common.BackgroundURL,
        assetPlaceholder: i18n.reusablePuzzleApps.Common.BackgroundURLPlaceholder,
        assetFilter: "image",
        assetRequired: false,
        allowEmpty: true
    }) %>
</div>
<br>

<script>
    document.getElementById('skinSelect').addEventListener('change', function() {
        var showLightFeedbackDiv = document.getElementById("showLightFeedbackDiv");
        if (this.value === 'RETRO') {
            showLightFeedbackDiv.style.display = 'flex';
        } else {
            showLightFeedbackDiv.style.display = 'none';
        }
    });

    document.getElementById('actionValue').addEventListener('change', function() {
        var messageDiv = document.getElementById("messageDiv");
        var soundDiv = document.getElementById("soundDiv");
        if (this.value === 'SHOW_MESSAGE') {
            messageDiv.style.display = 'flex';
        } else {
            messageDiv.style.display = 'none';
        }
        if (this.value === 'PLAY_SOUND') {
            soundDiv.style.display = 'flex';
        } else {
            soundDiv.style.display = 'none';
        }
    });

    document.getElementById("skinSelect").value =  window.currentOpenPuzzleConfig?.skin || 'STANDARD';
    document.getElementById("showLightFeedback").value =  window.currentOpenPuzzleConfig?.showLightFeedback || 'FALSE';
    document.getElementById("keysType").value =  window.currentOpenPuzzleConfig?.keysType || 'NUMBERS';

    document.getElementById("messageInput").value =  window.currentOpenPuzzleConfig?.message || '';
    document.getElementById("soundInput").value =  window.currentOpenPuzzleConfig?.soundAfterSolve || '';
    document.getElementById("actionValue").value =  window.currentOpenPuzzleConfig?.actionAfterSolve || 'NONE';
       
    document.getElementById("disablePhoneAfterSolve").value =  window.currentOpenPuzzleConfig?.disablePhoneAfterSolve || 'FALSE';
    
    //Trigger change events
    document.getElementById('actionValue').dispatchEvent(new Event('change', { bubbles: true }));
    document.getElementById('skinSelect').dispatchEvent(new Event('change', { bubbles: true }));
</script>