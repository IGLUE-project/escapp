<br>
<%- include ("./_validator.ejs", {allowedValidators: ["exact"], allowedNullPuzzle: true}, ) %>
<br>
<h4 class="titleLabelEdit"> <%=i18n.escapeRoom.steps.indications.front.catalog.config.customization%> </h4>

<div>
    <label for="skinSelect"><%=i18n.reusablePuzzleApps.Common.skin%>:</label>
    <select id="skinSelect" name="skin">
        <option value="STANDARD"><%=i18n.reusablePuzzleApps.Common.skins.Smartphone%></option>
        <option value="RETRO"><%=i18n.reusablePuzzleApps.Telephone.rotaryPhone%></option>
    </select>
</div>

<div id="showLightFeedbackDiv">
    <label for="showLightFeedback"><%=i18n.reusablePuzzleApps.Telephone.showFeedbackLight%>:</label>
    <select name="showLightFeedback" id="showLightFeedback">
        <option value="TRUE"><%=i18n.reusablePuzzleApps.Common.Yes%></option>
        <option value="FALSE"><%=i18n.reusablePuzzleApps.Common.No%></option>
    </select>
</div>

<div>
    <label for=""><%=i18n.reusablePuzzleApps.Telephone.elementType%>:</label>
    <select name="keysType" id="keysType">
        <option value="NUMBERS"><%=i18n.reusablePuzzleApps.Common.Numbers%></option>
        <option value="LETTERS"><%=i18n.reusablePuzzleApps.Common.Letters%></option>
        <option value="COLORS"><%=i18n.reusablePuzzleApps.Common.Colors%></option>
        <option value="SYMBOLS"><%=i18n.reusablePuzzleApps.Common.Symbols%></option>
    </select>
</div>

<div>
    <label for="actionValue"><%=i18n.reusablePuzzleApps.Common.actionAfterSolve%>:</label>
    <select id="actionValue" name="actionAfterSolve">
        <option value="NONE"><%=i18n.reusablePuzzleApps.Common.NoneF%></option>
        <option value="SHOW_MESSAGE"><%=i18n.reusablePuzzleApps.Common.showMessage%></option>
        <option value="PLAY_SOUND"><%=i18n.reusablePuzzleApps.Common.playSound%></option>
    </select>
</div>

<div id="messageDiv">
    <label for="messageInput"><%=i18n.reusablePuzzleApps.Common.Message%>:</label>
    <input id="messageInput" type="text" name="message" placeholder="<%=i18n.reusablePuzzleApps.Common.MessagePlaceholder%>" style="flex:1;"  />
</div>

<div id="soundDiv">
    <label for="soundInput"><%=i18n.reusablePuzzleApps.Common.soundURL%>:</label>
    <input type="text" id="soundInput" name="soundAfterSolve" placeholder="<%=i18n.reusablePuzzleApps.Common.soundURLPlaceholder%>" style="flex:1;" />
</div>

<div>
    <label for="disablePhoneAfterSolve"><%=i18n.reusablePuzzleApps.Common.disableAfterSolve%>:</label>
    <select name="disablePhoneAfterSolve" id="disablePhoneAfterSolve">
        <option value="TRUE"><%=i18n.reusablePuzzleApps.Common.Yes%></option>
        <option value="FALSE"><%=i18n.reusablePuzzleApps.Common.No%></option>
    </select>
</div>

<div class="contactsDivTelephone" style="flex-direction: column; border: 1px solid white; padding: 0px 10px 5px 10px; border-radius: 20px;">
    <label><%=i18n.reusablePuzzleApps.Telephone.contacts%></label>
    <div class="contactWrapperTelephoneTemplate" style="display:none; flex-direction: column; border: 1px solid white; padding: 0px 10px 5px 10px; border-radius: 20px; margin: 10px 0px 10px 0px;">
        <div style="position: relative;">
            <p style="margin: 7px 0px 5px 0px;"></p>
            <button class="deleteContactTelephone" type="button" style="display:none; border: none; background: none; position: absolute; right: 0; align-self: center; font-size: 22px;" onclick="deleteContactTelephone(event)">
                <span style="color: rgb(185, 62, 68);" class="material-icons">delete_outline</span>
            </button>
        </div>
        <div>
            <label><%=i18n.reusablePuzzleApps.Telephone.sequence%>:</label>
            <input class="inputContactSequence" type="text" style="flex:1;" />
        </div>
        <div style="margin: 10px 0px 10px 0px;">
            <label><%=i18n.reusablePuzzleApps.Common.soundURL%>:</label>
            <input class="inputContactSound" type="text" style="flex:1;" />
        </div>
        <div style="margin: 10px 0px 10px 0px;">
            <label><%=i18n.reusablePuzzleApps.Telephone.avatar%>:</label>
            <input class="inputContactAvatar" type="text" style="flex:1;" />
        </div>
    </div>
    <button class="rounded small addNewContactTelephone" type="button" onclick="addContactTelephone(event);" style="background-color: white; margin-top: 5px; margin-bottom: 10px"><span class="material-icons" style="color: #161938">add</span></button>
</div>

<div>
    <%- include ("./_asset.ejs", {
        assetId: "backgroundInput",
        assetName: "background",
        assetLabel: i18n.reusablePuzzleApps.Common.BackgroundURL,
        assetPlaceholder: i18n.reusablePuzzleApps.Common.BackgroundURLPlaceholder,
        assetFilter: "image",
        assetRequired: false,
        allowEmpty: true
    }) %>
</div>
<br>

<input type="hidden" class="reusablePuzzleJSONSetting" id="contactsTelephone" name="telephoneNumbers"/>

<script>
    var maxContactsTelephoneRP = 999;
    function addContactTelephoneToDiv($contactsWrapper){
        if ($contactsWrapper.length === 0) return;
        const $contactTemplate = $contactsWrapper.find('.contactWrapperTelephoneTemplate');
        if ($contactTemplate.length === 0) return;
        const $allContacts = $contactsWrapper.find('.contactWrapperTelephone');
        var contactNumber = $allContacts.length + 1;
        if (contactNumber > maxContactsTelephoneRP) return;
        const $newContact = $contactTemplate.clone();
        $newContact.removeClass("contactWrapperTelephoneTemplate").addClass("contactWrapperTelephone");

        $newContact.attr("contactNumber",contactNumber);
        $newContact.find('p').first().html('<%=i18n.reusablePuzzleApps.Telephone.contact%> ' + contactNumber);
        $newContact.find('button.deleteContactTelephone').first().show();
        $newContact.find('input.inputContactSequence').val('');
        $newContact.find('input.inputContactSound').val('');
        $newContact.find('input.inputContactAvatar').val('');
        $contactsWrapper.find('button').last().before($newContact);
        if(contactNumber === maxContactsTelephoneRP){
            var $addNewContactButton = $contactsWrapper.find('button.addNewContactTelephone');
            $addNewContactButton.attr("disabled","disabled");
            $addNewContactButton.css("background-color", "#999");
        }
        $newContact.show();
    };
    function addContactTelephone(e){
        e.stopPropagation();
        e.preventDefault();
        const $contactsWrapper = $(e.target).closest('.contactsDivTelephone');
        return addContactTelephoneToDiv($contactsWrapper);
    };
    function deleteContactTelephone(e){
        e.stopPropagation();
        e.preventDefault();
        const $contactWrapper = $(e.target).closest('.contactWrapperTelephone');
        if ($contactWrapper.length !== 1) return;
        const $contactsWrapper = $($contactWrapper).parent('.contactsDivTelephone');
        if ($contactsWrapper.length !== 1) return;
        $contactWrapper.remove();
        $contactsWrapper.find('.contactWrapperTelephone').each(function(index) {
            $(this).find('p').first().text('<%=i18n.reusablePuzzleApps.Telephone.contact%> ' + (index+1));
        });
        var $addContactButton = $contactsWrapper.find('button.addNewContactTelephone');
        $addContactButton.removeAttr("disabled");
        $addContactButton.css("background-color", "white");
        updateContactsTelephone();
        updateIframe();
    };
    function updateContactsTelephone(){
        var contacts = [];
        document.querySelectorAll('div.contactWrapperTelephone').forEach(div => {
            var contact = {};
            var addContact = false;
            const inputContactSequence = div.querySelector('input.inputContactSequence');
            const inputContactSound = div.querySelector('input.inputContactSound');
            const inputContactAvatar = div.querySelector('input.inputContactAvatar');

            if(inputContactSequence.value.trim()!==""){
                contact.number = inputContactSequence.value;
                addContact = true;
            }
            if(inputContactSound.value.trim()!==""){
                contact.audio = inputContactSound.value;
                addContact = true;
            }
            if(inputContactAvatar.value.trim()!==""){
                contact.avatar = inputContactAvatar.value;
                addContact = true;
            }
            if(addContact){
               contacts.push(contact); 
            }
        });
        document.getElementById("contactsTelephone").value = JSON.stringify(contacts);
    };

    if(window.currentOpenPuzzleConfig?.telephoneNumbers){
        var contacts = window.currentOpenPuzzleConfig?.telephoneNumbers;
        if (Array.isArray(contacts)){
            document.getElementById("contactsTelephone").value = JSON.stringify(contacts);
            var $contactsWrapper = $("div.contactsDivTelephone");
            for(var i=0; i<contacts.length; i++){
                var contactNumber = (i+1);
                addContactTelephoneToDiv($contactsWrapper);
                var $contactDiv = $contactsWrapper.find("div.contactWrapperTelephone[contactNumber='" + contactNumber + "']");
                $contactDiv.find("input.inputContactSequence").val(contacts[i].number);
                $contactDiv.find("input.inputContactSound").val(contacts[i].audio);
                $contactDiv.find("input.inputContactAvatar").val(contacts[i].avatar);
            };
        }

    }

    document.getElementById('skinSelect').addEventListener('change', function() {
        var showLightFeedbackDiv = document.getElementById("showLightFeedbackDiv");
        if (this.value === 'RETRO') {
            showLightFeedbackDiv.style.display = 'flex';
        } else {
            showLightFeedbackDiv.style.display = 'none';
        }
    });

    document.getElementById('actionValue').addEventListener('change', function() {
        var messageDiv = document.getElementById("messageDiv");
        var soundDiv = document.getElementById("soundDiv");
        if (this.value === 'SHOW_MESSAGE') {
            messageDiv.style.display = 'flex';
        } else {
            messageDiv.style.display = 'none';
        }
        if (this.value === 'PLAY_SOUND') {
            soundDiv.style.display = 'flex';
        } else {
            soundDiv.style.display = 'none';
        }
    });

    $('div.contactsDivTelephone').on('change',
        'input.inputContactSequence, input.inputContactSound, input.inputContactAvatar',
        updateContactsTelephone
    );

    document.getElementById("skinSelect").value =  window.currentOpenPuzzleConfig?.skin || 'STANDARD';
    document.getElementById("showLightFeedback").value =  window.currentOpenPuzzleConfig?.showLightFeedback || 'FALSE';
    document.getElementById("keysType").value =  window.currentOpenPuzzleConfig?.keysType || 'NUMBERS';

    document.getElementById("messageInput").value =  window.currentOpenPuzzleConfig?.message || '';
    document.getElementById("soundInput").value =  window.currentOpenPuzzleConfig?.soundAfterSolve || '';
    document.getElementById("actionValue").value =  window.currentOpenPuzzleConfig?.actionAfterSolve || 'NONE';
       
    document.getElementById("disablePhoneAfterSolve").value =  window.currentOpenPuzzleConfig?.disablePhoneAfterSolve || 'FALSE';
    
    //Trigger change events
    document.getElementById('actionValue').dispatchEvent(new Event('change', { bubbles: true }));
    document.getElementById('skinSelect').dispatchEvent(new Event('change', { bubbles: true }));
</script>