<%
    // Default parameters
    var assetLabel = (typeof assetLabel !== "undefined") ? assetLabel : i18n.escapeRoom.steps.assets.title;
    var assetName = (typeof assetName !== "undefined") ? assetName : "assetId";
    var assetId = (typeof assetId !== "undefined") ? assetId : "assetSelect";
    var assetPlaceholder = (typeof assetPlaceholder !== "undefined") ? assetPlaceholder : i18n.escapeRoom.steps.assets.title;
    var assetRequired = (typeof assetRequired !== "undefined") ? assetRequired : false;
    var assetFilter = (typeof assetFilter !== "undefined") ? assetFilter : null; // e.g., "image", "audio", "video", "webapp", "pdf"
    var allowEmpty = (typeof allowEmpty !== "undefined") ? allowEmpty : true;
%>

<div style="position: relative;">
    <label for="<%= assetId %>"><%= assetLabel %>:</label>
    <div style="display: flex; align-items: center; flex: 1;">
        <input type="text"
               id="<%= assetId %>"
               name="<%= assetName %>"
               list="<%= assetId %>List"
               placeholder="<%= assetPlaceholder %>"
               <%= assetRequired ? 'required' : '' %>
               style="flex:1;" />
        <button type="button"
                id="<%= assetId %>Clear"
                style="display: none; border: none; background: none; cursor: pointer; padding: 0 5px; font-size: 18px; color: rgb(185, 62, 68);">
            <span class="material-icons">close</span>
        </button>
    </div>
    <datalist id="<%= assetId %>List"></datalist>
</div>

<script>
(function() {
    const inputEl = document.getElementById('<%= assetId %>');
    const datalistEl = document.getElementById('<%= assetId %>List');
    const assetFilter = '<%= assetFilter || "" %>';
    const configValue = window.currentOpenPuzzleConfig?.['<%= assetName %>'] || '';
    const origin = window.location.origin;

    // Filter assets if a filter type is specified
    let filteredAssets = window.assets || [];
    if (assetFilter) {
        filteredAssets = filteredAssets.filter(asset => {
            if (!asset.assetType) return false;
            return asset.assetType.toLowerCase().includes(assetFilter.toLowerCase());
        });
    }

    // Create mapping between filenames and URLs
    const assetMap = {};
    const urlToName = {};

    // Populate datalist with assets (using filename as value for display)
    filteredAssets.forEach(asset => {
        // Ensure URL has full absolute path with hostname
        let url = asset.url || `/assets/${asset.id}`;
        if (url.startsWith('/')) {
            url = origin + url;
        } else if (!url.startsWith('http')) {
            url = origin + '/assets/' + url;
        }

        assetMap[asset.filename] = url;
        urlToName[url] = asset.filename;

        const option = document.createElement('option');
        option.value = asset.filename;
        option.setAttribute('data-url', url);
        option.setAttribute('data-id', asset.id);
        datalistEl.appendChild(option);
    });

    // Clear button
    const clearBtn = document.getElementById('<%= assetId %>Clear');

    function updateClearButton() {
        clearBtn.style.display = inputEl.value ? 'block' : 'none';
    }

    // Clear button click handler
    clearBtn.addEventListener('click', function() {
        inputEl.value = '';
        this.style.display = 'none';
        inputEl.dispatchEvent(new Event('change', { bubbles: true }));
    });

    // Convert filename to URL when user selects from datalist
    inputEl.addEventListener('change', function() {
        const selectedName = this.value;
        if (assetMap[selectedName]) {
            this.value = assetMap[selectedName];
        }
        updateClearButton();
    });

    // Set initial value from config (show URL or convert URL to name for display)
    if (configValue) {
        inputEl.value = configValue;
    }
    updateClearButton();

    // Show/hide clear button on input change
    inputEl.addEventListener('input', updateClearButton);
})();
</script>
