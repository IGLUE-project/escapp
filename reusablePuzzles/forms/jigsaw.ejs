<br>
<%- include ("./_validator.ejs", {allowedValidators: ["exact"], allowedNullPuzzle: true}, ) %>
<br>
<h4 class="titleLabelEdit"> <%=i18n.escapeRoom.steps.indications.front.catalog.config.customization%> </h4>

<div>
    <label for="skinSelect"><%=i18n.reusablePuzzleApps.Common.skin%>:</label>
    <select id="skinSelect" name="skin">
        <option value="STANDARD"><%=i18n.reusablePuzzleApps.Common.skins.Standard%></option>
        <option value="FRAMED"><%=i18n.reusablePuzzleApps.Common.skins.Framed%></option>
    </select>
</div>

<div>
    <%- include ("./_asset.ejs", {
        assetId: "imageSolJigsaw",
        assetName: "imageSol",
        assetLabel: i18n.reusablePuzzleApps.Jigsaw.solutionImage,
        assetPlaceholder: i18n.reusablePuzzleApps.Common.BackgroundURLPlaceholder,
        assetFilter: "image",
        assetRequired: false,
        allowEmpty: true
    }) %>
</div>

<div>
    <%- include ("./_asset.ejs", {
        assetId: "imageSolReverseJigsaw",
        assetName: "imageSolReverse",
        assetLabel: i18n.reusablePuzzleApps.Jigsaw.solutionImageReverse,
        assetPlaceholder: i18n.reusablePuzzleApps.Common.BackgroundURLPlaceholder,
        assetFilter: "image",
        assetRequired: false,
        allowEmpty: true
    }) %>
</div>

<div>
    <label for="jigsawWidth"><%=i18n.reusablePuzzleApps.Common.Width%>:</label>
    <select name="cols" id="jigsawWidth">
        <% for (let i = 1; i <= 10; i++) { %>
            <option value="<%= i %>" <%= i === 8 ? "selected" : "" %>><%= i %></option>
        <% } %>
    </select>
</div>

<div>
    <label for="jigsawHeight"><%=i18n.reusablePuzzleApps.Common.Height%>:</label>
    <select name="rows" id="jigsawHeight">
        <% for (let i = 1; i <= 10; i++) { %>
            <option value="<%= i %>" <%= i === 4 ? "selected" : "" %>><%= i %></option>
        <% } %>
    </select>
</div>

<div>
    <%- include ("./_asset.ejs", {
        assetId: "backgroundImgInput",
        assetName: "backgroundImg",
        assetLabel: i18n.reusablePuzzleApps.Common.BackgroundURL,
        assetPlaceholder: i18n.reusablePuzzleApps.Common.BackgroundURLPlaceholder,
        assetFilter: "image",
        assetRequired: false,
        allowEmpty: true
    }) %>
</div>
<br>

<script>
    document.getElementById("skinSelect").value =  window.currentOpenPuzzleConfig?.skin || 'STANDARD';
    document.getElementById("jigsawWidth").value =  window.currentOpenPuzzleConfig?.cols || 4;
    document.getElementById("jigsawHeight").value =  window.currentOpenPuzzleConfig?.rows || 3;
</script>